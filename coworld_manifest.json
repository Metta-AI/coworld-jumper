{
  "$schema": "https://raw.githubusercontent.com/Metta-AI/metta/main/packages/coworld/src/coworld/coworld_manifest_schema.json",
  "game": {
    "name": "jumper",
    "version": "0.1.0",
    "description": "A cooperative BitWorld platformer where players cross pits, stack on each other, and reach the flag.",
    "owner": "treeform@softmax.com",
    "runnable": {
      "type": "game",
      "image": "ghcr.io/treeform/bitworld-jumper:latest",
      "run": ["/bin/jumper"]
    },
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens"
      ],
      "properties": {
        "tokens": {
          "description": "One connection token per player slot, indexed by slot.",
          "type": "array",
          "minItems": 0,
          "maxItems": 64,
          "items": {
            "type": "string",
            "minLength": 0
          },
          "default": []
        },
        "seed": {
          "description": "Random seed.",
          "type": "integer",
          "minimum": 0,
          "default": 727920
        },
        "maxTicks": {
          "description": "Maximum simulation ticks before starting a fresh game, where 0 means no tick limit.",
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "maxGames": {
          "description": "Maximum fresh games before shutdown, where 0 means no game limit.",
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "protocols": {
      "global": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
      },
      "player": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
      }
    }
  },
  "player": [
    {
      "id": "dalli",
      "name": "dalli",
      "description": "Coworld player for jumper.",
      "runnable": {
        "type": "player",
        "image": "ghcr.io/treeform/bitworld-jumper-dalli:latest",
        "run": ["/bin/dalli"]
      }
    }
  ],
  "variants": [
    {
      "id": "freeplay",
      "name": "Freeplay",
      "game_config": {
        "seed": 727920,
        "maxTicks": 0,
        "maxGames": 0
      },
      "description": "Open-ended Jumper configuration for local player testing."
    },
    {
      "id": "smoke",
      "name": "Smoke",
      "game_config": {
        "seed": 727920,
        "maxTicks": 300,
        "maxGames": 1
      },
      "description": "Short deterministic Jumper configuration used for manifest checks."
    }
  ],
  "certification": {
    "variant_id": "smoke",
    "players": [
      {
        "player_id": "dalli",
        "initial_params": {
          "name": "slot_0"
        }
      },
      {
        "player_id": "dalli",
        "initial_params": {
          "name": "slot_1"
        }
      }
    ]
  }
}
