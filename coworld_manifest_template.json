{
  "$schema": "https://raw.githubusercontent.com/Metta-AI/metta/main/packages/coworld/src/coworld/coworld_manifest_schema.json",
  "game": {
    "name": "jumper",
    "description": "A cooperative BitWorld platformer where players cross pits, stack on each other, and reach the flag.",
    "owner": "treeform@softmax.com",
    "runnable": {
      "type": "game",
      "image": "{{GAME_IMAGE}}",
      "run": [
        "/bin/jumper"
      ],
      "source_url": "https://github.com/Metta-AI/coworld-jumper/tree/master"
    },
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens"
      ],
      "properties": {
        "tokens": {
          "description": "One connection token per player slot, indexed by slot.",
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "string",
            "minLength": 0
          },
          "default": [
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            ""
          ]
        },
        "seed": {
          "description": "Random seed.",
          "type": "integer",
          "minimum": 0,
          "default": 727920
        },
        "maxTicks": {
          "description": "Maximum simulation ticks before starting a fresh game, where 0 means no tick limit.",
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "maxGames": {
          "description": "Maximum fresh games before shutdown, where 0 means no game limit.",
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "num_agents": {
          "description": "Player seat count used by hosted league seating.",
          "type": "integer",
          "minimum": 1,
          "maximum": 8,
          "default": 8
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "names",
        "scores"
      ],
      "properties": {
        "names": {
          "description": "Player display names in seat slot order.",
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "string"
          }
        },
        "scores": {
          "description": "Flag captures per seat slot at the end of the game.",
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "protocols": {
      "global": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
      },
      "player": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
      }
    },
    "docs": {
      "readme": {
        "type": "text",
        "value": "# Jumper\n\nCooperative Coworld platformer where players cross pits, stack on each other, and reach the flag."
      },
      "pages": [
        {
          "id": "rules.md",
          "title": "rules.md",
          "content": {
            "type": "text",
            "value": "# Jumper Rules\n\nPlayers move through a side-scrolling platform level, cross pits, stack on each other when needed, and try to reach the flag. Reaching the flag scores one point and respawns the player at the start. Falling below the level respawns the player. The player with the most flag captures when time runs out wins."
          }
        },
        {
          "id": "play_jumper.md",
          "title": "play_jumper.md",
          "content": {
            "type": "text",
            "value": "# Play Jumper\n\nConnect with the sprite protocol player websocket, move right through the level, jump over gaps and walls, and cooperate with other players to cross larger hazards. The bundled dalli player is a deterministic flag-seeking baseline bot."
          }
        }
      ]
    }
  },
  "player": [
    {
      "id": "dalli",
      "name": "dalli",
      "type": "player",
      "description": "Deterministic flag-seeking baseline Jumper bot.",
      "image": "{{DALLI_IMAGE}}",
      "run": [
        "/bin/dalli"
      ],
      "source_url": "https://github.com/Metta-AI/coworld-jumper/tree/master/players/dalli"
    }
  ],
  "commissioner": [
    {
      "id": "default-commissioner",
      "name": "Default Commissioner",
      "type": "commissioner",
      "description": "Game-agnostic round-robin commissioner with mean-score rankings, configured for hourly Jumper rounds.",
      "source_url": "https://github.com/Metta-AI/commissioners/tree/fa8ac7cb2bc6fd54c5675c7993919afabebcf4ba/commissioners/ruleset_strategy_commissioner",
      "image": "{{COMMISSIONER_IMAGE}}"
    }
  ],
  "reporter": [],
  "grader": [
    {
      "id": "bitworld-score-grader",
      "name": "BitWorld Score Grader",
      "type": "grader",
      "description": "Generic BitWorld grader that scores episode interest from score spread and game-specific activity signals.",
      "source_url": "https://github.com/Metta-AI/coworld-jumper/tree/master/grader/graders/bitworld_score/bitworld_score_grader",
      "image": "{{GRADER_IMAGE}}"
    }
  ],
  "variants": [
    {
      "id": "league",
      "name": "League",
      "game_config": {
        "seed": 727920,
        "maxTicks": 4320,
        "maxGames": 1,
        "num_agents": 8
      },
      "description": "One bounded three-minute Jumper game used for hosted league rounds."
    },
    {
      "id": "freeplay",
      "name": "Freeplay",
      "game_config": {
        "seed": 727920,
        "maxTicks": 0,
        "maxGames": 0
      },
      "description": "Open-ended Jumper configuration for local player testing."
    },
    {
      "id": "smoke",
      "name": "Smoke",
      "game_config": {
        "seed": 727920,
        "maxTicks": 300,
        "maxGames": 1
      },
      "description": "Short deterministic Jumper configuration used for manifest checks."
    }
  ],
  "certification": {
    "game_config": {
      "seed": 727920,
      "maxTicks": 300,
      "maxGames": 1
    },
    "players": [
      {
        "player_id": "dalli"
      },
      {
        "player_id": "dalli"
      },
      {
        "player_id": "dalli"
      },
      {
        "player_id": "dalli"
      },
      {
        "player_id": "dalli"
      },
      {
        "player_id": "dalli"
      },
      {
        "player_id": "dalli"
      },
      {
        "player_id": "dalli"
      }
    ]
  },
  "players_per_user": 8
}
